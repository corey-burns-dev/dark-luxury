---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { journalEntries, findJournalBySlug } from '../../data/storefront';

export function getStaticPaths() {
  return journalEntries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;
const article = slug ? findJournalBySlug(slug) : null;

if (!article) {
  return Astro.redirect('/404');
}

const relatedArticles = journalEntries.filter((entry) => entry.slug !== article.slug).slice(0, 3);
---

<Layout title={article.title} description={article.excerpt}>
  <section class="content-wrap article-header">
    <div class="product-crumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/journal">Journal</a>
      <span>/</span>
      <strong>{article.title}</strong>
    </div>
    <p class="kicker">
      {article.topic} | {article.published}
    </p>
    <h1>{article.title}</h1>
    <p>{article.excerpt}</p>
  </section>

  <section class="content-wrap article-layout">
    <article class="article-copy">
      <Image 
        src={article.image} 
        alt={article.title} 
        width={1000} 
        height={600}
        loading="eager" 
      />
      <p>{article.body}</p>
      <p>
        We document each release through a strict review cycle: materials audit, wear testing,
        and post-delivery feedback. This operating rhythm keeps the collection coherent while
        improving fit, performance, and durability over time.
      </p>
      <p>
        If you would like product recommendations related to this article, our concierge team
        can assemble a shortlist tailored to your wardrobe, travel profile, and seasonal use.
      </p>
      <p class="journal-meta">{article.readTime}</p>
      <div class="hero-actions">
        <a class="button button-primary" href="/shop">
          Shop related pieces
        </a>
        <a class="button button-ghost" href="/journal">
          Back to journal
        </a>
      </div>
    </article>
  </section>

  <section class="section content-wrap">
    <div class="section-head">
      <h2>More from the Journal</h2>
      <a href="/journal">All stories</a>
    </div>

    <div class="journal-grid">
      {relatedArticles.map((entry) => (
        <article>
          <a href={`/journal/${entry.slug}`}>
            <Image 
              src={entry.image} 
              alt={entry.title} 
              width={400} 
              height={300}
              loading="lazy" 
            />
          </a>
          <div class="journal-card-body">
            <small>
              {entry.topic} | {entry.published}
            </small>
            <h3>{entry.title}</h3>
            <p>{entry.excerpt}</p>
            <p class="journal-meta">{entry.readTime}</p>
            <a class="button button-line" href={`/journal/${entry.slug}`}>
              Continue reading
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
